{
  "datasets": [
    {
      "name": "59d476f5",
      "displayName": "master_loan_dataset",
      "queryLines": [
        "SELECT\n",
        "  f.loan_id,\n",
        "  f.disbursement_date,\n",
        "  f.loan_status,\n",
        "  f.loan_amount,\n",
        "  f.funded_amount,\n",
        "  f.total_payment_received,\n",
        "  f.outstanding_principal,\n",
        "  f.total_interest_received,\n",
        "  f.total_late_fees_received,\n",
        "  b.employment_title,\n",
        "  b.employment_length_years,\n",
        "  b.home_ownership,\n",
        "  b.annual_income,\n",
        "  b.address_state,\n",
        "  b.dti,\n",
        "  b.has_prior_delinq,\n",
        "  l.grade,\n",
        "  l.loan_term_months,\n",
        "  l.interest_rate,\n",
        "  l.loan_purpose\n",
        "FROM\n",
        "  workspace.gold.fact_loans f\n",
        "    LEFT JOIN workspace.gold.dim_borrower b\n",
        "      ON f.member_id = b.member_id\n",
        "    LEFT JOIN workspace.gold.dim_loan_info l\n",
        "      ON f.loan_id = l.loan_id"
      ],
      "columns": [
        {
          "displayName": "total_charged_off",
          "description": "Total funded amount for charged off loans",
          "expression": "SUM(CASE WHEN `loan_status` = 'Charged Off' THEN `funded_amount` ELSE 0 END)"
        },
        {
          "displayName": "bad_debt_ratio_pct",
          "description": "Bad debt ratio as percentage",
          "expression": "(SUM(CASE WHEN `loan_status` = 'Charged Off' THEN `funded_amount` ELSE 0 END) * 100.0) / SUM(`funded_amount`)"
        }
      ],
      "catalog": "workspace",
      "schema": "gold"
    },
    {
      "name": "blacklist_top_100",
      "displayName": "Top 100 Blacklist",
      "queryLines": [
        "SELECT\n",
        "  f.loan_id,\n",
        "  f.disbursement_date,\n",
        "  f.loan_status,\n",
        "  f.loan_amount,\n",
        "  f.funded_amount,\n",
        "  f.total_payment_received,\n",
        "  f.outstanding_principal,\n",
        "  f.total_interest_received,\n",
        "  f.total_late_fees_received,\n",
        "  b.employment_title,\n",
        "  b.employment_length_years,\n",
        "  b.home_ownership,\n",
        "  b.annual_income,\n",
        "  b.address_state,\n",
        "  b.dti,\n",
        "  b.has_prior_delinq,\n",
        "  l.grade,\n",
        "  l.loan_term_months,\n",
        "  l.interest_rate,\n",
        "  l.loan_purpose\n",
        "FROM\n",
        "  workspace.gold.fact_loans f\n",
        "    LEFT JOIN workspace.gold.dim_borrower b\n",
        "      ON f.member_id = b.member_id\n",
        "    LEFT JOIN workspace.gold.dim_loan_info l\n",
        "      ON f.loan_id = l.loan_id\n",
        "WHERE\n",
        "  f.loan_status = 'Charged Off'\n",
        "ORDER BY\n",
        "  f.outstanding_principal DESC\n",
        "LIMIT 100"
      ],
      "catalog": "workspace",
      "schema": "gold"
    }
  ],
